{% if hourly %}
  {% set iconSet = (config.iconset or "") | lower %}
  {% set hasCustomIconSet = iconSet in ["mm", "1s", "5a", "2s", "3s", "2a", "4af", "4al"] %}
  {% set iconTypeMap = {
    "day-sunny": "01d",
    "night-clear": "01n",
    "day-cloudy": "02d",
    "night-alt-cloudy": "02n",
    "night-cloudy": "04n",
    "day-sunny-overcast": "02d",
    "night-alt-partly-cloudy": "02n",
    "cloud": "03d",
    "cloudy": "04d",
    "cloudy-windy": "04d",
    "night-alt-cloudy-windy": "04n",
    "day-showers": "09d",
    "night-alt-showers": "09n",
    "night-showers": "09n",
    "showers": "09d",
    "day-sprinkle": "09d",
    "night-alt-sprinkle": "09n",
    "night-sprinkle": "09n",
    "sprinkle": "09d",
    "day-rain": "10d",
    "night-alt-rain": "10n",
    "night-rain": "10n",
    "rain": "10d",
    "day-rain-mix": "09d",
    "night-alt-rain-mix": "09n",
    "night-rain-mix": "09n",
    "rain-mix": "09d",
    "day-sleet": "09d",
    "night-alt-sleet": "09n",
    "night-sleet": "09n",
    "sleet": "09d",
    "day-sleet-storm": "11d",
    "night-alt-sleet-storm": "11n",
    "night-sleet-storm": "11n",
    "day-storm-showers": "11d",
    "night-alt-storm-showers": "11n",
    "day-hail": "09d",
    "night-alt-hail": "09n",
    "day-thunderstorm": "11d",
    "night-alt-thunderstorm": "11n",
    "night-thunderstorm": "11n",
    "day-snow-thunderstorm": "11d",
    "night-snow-thunderstorm": "11n",
    "thunderstorm": "11d",
    "day-snow": "13d",
    "night-alt-snow-wind": "13n",
    "night-alt-snow": "13n",
    "night-partly-cloudy": "02n",
    "night-snow": "13n",
    "day-snow-wind": "13d",
    "night-snow-wind": "13n",
    "snowflake-cold": "13d",
    "snow": "13d",
    "day-fog": "50d",
    "night-fog": "50n",
    "day-haze": "50d",
    "smoke": "50d",
    "dust": "50d",
    "windy": "04d",
    "strong-wind": "04d",
    "fog": "50d",
    "mist": "50d"
  } %}
  {% if hasCustomIconSet %}
    {% set iconFormat = "png" if iconSet == "1s" else "svg" %}
  {% endif %}
  {% set numSteps = hourly | calcNumEntries %}
  {% set currentStep = 0 %}
  {% set hours = hourly.slice(0, numSteps) %}

  <div class="mmtw-hourly mmtw-table-wrap">
    <table class="mmtw-table mmtw-table-hourly">
      <tbody>
        {% for hour in hours %}
          <tr class="mmtw-table-row"{% if config.fade %} style="opacity: {{ currentStep | opacity(numSteps) }};"{% endif %}>
            <td class="mmtw-col-day">{{ hour.date | formatTime }}</td>
            <td class="mmtw-col-icon">
              <span class="mmtw-icon-slot">
                {% set mappedIconType = iconTypeMap[hour.weatherType] or hour.weatherType %}
                {% set customIconType = mappedIconType if mappedIconType in ["01d", "01n", "02d", "02n", "03d", "03n", "04d", "04n", "09d", "09n", "10d", "10n", "11d", "11n", "13d", "13n", "50d", "50n"] else "03d" %}
                {% if hasCustomIconSet %}
                  <img class="mmtw-icon-img{% if iconSet == \"2a\" %} mmtw-icon-img-2a-compact{% endif %}" src="modules/MMT-WeatherOneTheme/icons/{{ iconSet }}/{{ customIconType }}.{{ iconFormat }}" alt="{{ customIconType }}">
                {% else %}
                  <span class="wi weathericon wi-{{ hour.weatherType }} mmtw-hour-icon"></span>
                {% endif %}
              </span>
            </td>
            <td class="mmtw-col-temp">{{ hour.temperature | roundValue | unit("temperature") | decimalSymbol }}</td>
            {% if config.showHumidity != "none" %}
              <td class="mmtw-col-metric">
                {% if hour.humidity is defined and hour.humidity is not none %}
                  <span class="wi wi-humidity"></span>
                  {{ hour.humidity }}<span class="mmtw-unit">%</span>
                {% else %}
                  <span class="mmtw-empty">-</span>
                {% endif %}
              </td>
            {% endif %}
            {% if config.showPrecipitationProbability %}
              <td class="mmtw-col-metric">
                {% if hour.precipitationProbability is defined and hour.precipitationProbability is not none %}
                  <span class="wi wi-raindrop"></span>
                  {{ hour.precipitationProbability | unit('precip', '%') }}
                {% else %}
                  <span class="mmtw-empty">-</span>
                {% endif %}
              </td>
            {% endif %}
            {% if config.showPrecipitationAmount %}
              <td class="mmtw-col-metric">
                {% if hour.precipitationAmount is defined and hour.precipitationAmount is not none and (not config.hideZeroes or hour.precipitationAmount > 0) %}
                  <span class="wi wi-umbrella"></span>
                  {{ hour.precipitationAmount | unit("precip", hour.precipitationUnits) }}
                {% else %}
                  <span class="mmtw-empty">-</span>
                {% endif %}
              </td>
            {% endif %}
            {% if config.showUVIndex %}
              <td class="mmtw-col-metric">
                {% if hour.uvIndex is defined and hour.uvIndex is not none and hour.uvIndex != 0 %}
                  <span class="wi wi-hot"></span>
                  {{ hour.uvIndex }}
                {% else %}
                  <span class="mmtw-empty">-</span>
                {% endif %}
              </td>
            {% endif %}
          </tr>
          {% set currentStep = currentStep + 1 %}
        {% endfor %}
      </tbody>
    </table>
  </div>
{% else %}
  <div class="dimmed light small">{{ "LOADING" | translate }}</div>
{% endif %}
